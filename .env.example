# ============================================================
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Supabase (get from supabase.com → Project Settings → API) ---
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- Server-side only (Vercel env vars, NOT VITE_ prefixed) ---
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here  # NOT the anon key — service role only

# --- Cron security (pick any random string) ---
CRON_SECRET=replace_with_random_string_32_chars

# --- Admin API (commissioner use only) ---
ADMIN_SECRET=replace_with_another_random_string
